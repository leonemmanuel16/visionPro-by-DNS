{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Dashboard (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "services/dashboard"
    },
    {
      "name": "API (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Camera Manager",
      "runtimeExecutable": "python",
      "runtimeArgs": ["main.py"],
      "port": 0
    },
    {
      "name": "Detector",
      "runtimeExecutable": "python",
      "runtimeArgs": ["main.py"],
      "port": 0
    }
  ]
}
