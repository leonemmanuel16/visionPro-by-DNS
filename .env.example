# DNS Vision Pro - Environment Variables
# Copy this file to .env and adjust values for your installation

# Database
DB_PASSWORD=changeme

# MinIO (Object Storage)
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# JWT Secret (change in production!)
JWT_SECRET=dns-vision-pro-secret-key-change-me

# ONVIF Camera Defaults
ONVIF_DEFAULT_USER=dns
ONVIF_DEFAULT_PASS=admin12345

# Detection Settings
MODEL_NAME=yolov10s
DETECTION_FPS=5
CONFIDENCE_THRESHOLD=0.80

# SMTP (Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=DNS Vision Pro
SMTP_USE_TLS=true

# Dashboard URLs (leave empty for auto-detection from browser)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GO2RTC_URL=
NEXT_PUBLIC_WS_URL=
