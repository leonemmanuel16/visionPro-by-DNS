# ============================================
# DNS VisionPro - Environment Configuration
# ============================================
# The install.sh script copies this to .env automatically.
# All values below work out-of-the-box. Change passwords in production!

# Database
DB_PASSWORD=changeme

# MinIO (Object Storage for snapshots/clips)
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# JWT Secret (CHANGE THIS in production!)
JWT_SECRET=dns-vision-pro-secret-key-change-me

# ONVIF Camera Discovery Defaults
ONVIF_DEFAULT_USER=dns
ONVIF_DEFAULT_PASS=admin12345

# Detection Settings
MODEL_NAME=yolo26s
DETECTION_FPS=10
CONFIDENCE_THRESHOLD=0.40

# GPU Settings (auto = use GPU if available, cpu = force CPU)
DEVICE=auto

# Ring Buffer (pre-event video clips)
RING_BUFFER_SECONDS=15

# SMTP (Email Notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=DNS Vision Pro
SMTP_USE_TLS=true

# Dashboard URLs (leave empty for auto-detection from browser)
# Only set these if behind a reverse proxy or custom domain
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GO2RTC_URL=
NEXT_PUBLIC_WS_URL=
