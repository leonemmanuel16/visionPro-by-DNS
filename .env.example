# ============================================
# DNS Vision Pro — Environment Configuration
# ============================================
# Copy this file to .env and adjust values.

# --- Database ---
DB_PASSWORD=VisionPro2025!

# --- MinIO (S3 storage for snapshots/clips) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-random-secret

# --- SMTP (Email alerts) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=DNS Vision Pro
SMTP_USE_TLS=true

# --- ONVIF Camera Defaults ---
ONVIF_DEFAULT_USER=admin
ONVIF_DEFAULT_PASS=admin12345

# --- Detector ---
MODEL_NAME=yolov10n
DETECTION_FPS=3
CONFIDENCE_THRESHOLD=0.5

# --- Frontend URLs (optional) ---
# Leave empty to auto-detect from browser window.location.
# Only set these if you need to override (e.g., reverse proxy, custom domain).
#
# NEXT_PUBLIC_API_URL=http://192.168.1.100:8000
# NEXT_PUBLIC_GO2RTC_URL=http://192.168.1.100:1984
# NEXT_PUBLIC_WS_URL=ws://192.168.1.100:8000/ws
